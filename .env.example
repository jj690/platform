# Secrets and database configuration
OPENAI_API_KEY=SUPER_SECRET_KEY
POSTGRES_DB_APPLICATION_TRACKER=application_tracker
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Platform
PLATFORM_PROTOCOL=http
PLATFORM_HOST=localhost
PLATFORM_HTTP_PORT=80
TIMEZONE=Europe/Berlin

# Networks
PROXY_NETWORK=platform-proxy
DATABASE_NETWORK=platform-database

# Images
TRAEFIK_IMAGE=traefik:3.6
N8N_IMAGE=n8nio/n8n:latest
ADMINER_IMAGE=adminer:latest
POSTGRES_IMAGE=postgres:17-alpine

# Traefik
TRAEFIK_PATH=/traefik
TRAEFIK_WEB_PORT=80
TRAEFIK_HEALTH_PORT=8082

# n8n
N8N_PATH=/n8n
N8N_PORT=5678

# Platform health endpoint
HEALTH_PATH=/health

# Application Tracker
TRACKER_API_PATH=/api/tracker
TRACKER_API_PORT=8000

TRACKER_PATH=/tracker
STREAMLIT_BASE_PATH=tracker
TRACKER_FRONTEND_PORT=8501

# Other applications
PORTAL_PATH=/
ADMINER_PATH=/adminer

# Health-check defaults
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5

# Router priorities
PRIORITY_TRAEFIK=200
PRIORITY_HEALTH=150
PRIORITY_API=120
PRIORITY_DEFAULT=100
PRIORITY_PORTAL=1