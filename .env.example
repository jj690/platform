# =============================================================================
# Platform configuration — copy to .env and adjust before running:
#   docker compose up -d
#
# Variables marked with (!) should be changed for production.
# =============================================================================

# --- Secrets ---------------------------------------------------------------

# (!) Your OpenAI API key
OPENAI_API_KEY= 
# Secrets and database configuration
POSTGRES_DB_APPLICATION_TRACKER=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password

# Platform
PLATFORM_PROTOCOL=https
PLATFORM_HOST=localhost
PLATFORM_HTTP_PORT=80
PLATFORM_HTTPS_PORT=443
TIMEZONE=Europe/Berlin


# Networks
PROXY_NETWORK=platform-proxy
DATABASE_NETWORK=platform-database

# Images
TRAEFIK_IMAGE=traefik:3.6
N8N_IMAGE=n8nio/n8n:latest
ADMINER_IMAGE=adminer:latest
POSTGRES_IMAGE=postgres:17-alpine

# Traefik
TRAEFIK_PATH=/traefik
TRAEFIK_WEB_PORT=80
TRAEFIK_HEALTH_PORT=8082
TRAEFIK_WEB_SECURE_PORT=443

# n8n
N8N_PATH=/n8n
N8N_PORT=5678

# Platform health endpoint
HEALTH_PATH=/health
SERVICES_HEALTH_PATH=/health/services

# Application Tracker
TRACKER_API_PATH=/api/tracker
TRACKER_API_PORT=8000

TRACKER_PATH=/tracker
STREAMLIT_BASE_PATH=tracker
TRACKER_FRONTEND_PORT=8501

# Other applications
PORTAL_PATH=/
ADMINER_PATH=/adminer

# Health-check defaults
HEALTHCHECK_INTERVAL=10s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=5

# Router priorities
PRIORITY_TRAEFIK=200
PRIORITY_HEALTH=150
PRIORITY_API=120
PRIORITY_DEFAULT=100
PRIORITY_PORTAL=1